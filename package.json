{
  "name": "log4j2-viewer",
  "version": "1.0.0",
  "description": "Desktop Log4j2 log viewer with local, tail, and paste support",
  "main": "dist-main/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "dev": "npm run build:main && concurrently \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "start": "electron .",
    "electron": "electron ."
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtuoso": "^4.6.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "wait-on": "^8.0.1",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.1"
  }
}
